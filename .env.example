APP_NAME=Cashbird
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cashbird
DB_USERNAME=cashbird
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WorkOS — see README for dashboard setup
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI="${APP_URL}/auth/callback"
WORKOS_ORGANIZATION_ID=

# AI — Cloudflare Workers AI through AI Gateway
# Create an AI Gateway at https://dash.cloudflare.com > AI > AI Gateway
# Gateway URL format: https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/workers-ai/v1
CLOUDFLARE_AI_GATEWAY_URL=
CLOUDFLARE_AI_API_TOKEN=
AI_MODEL_SMARTEST=@cf/zhipu/glm-4.7-flash
AI_MODEL_CHEAPEST=@cf/google/gemma-4-26b-a4b-it
AI_MODEL_DEFAULT=@cf/zhipu/glm-4.7-flash
AI_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
AI_EMBEDDING_DIMENSIONS=768

# To use a different provider instead of Cloudflare, set AI_PROVIDER
# and the corresponding API key (e.g., AI_PROVIDER=anthropic + ANTHROPIC_API_KEY)
# AI_PROVIDER=cloudflare

# Stripe Financial Connections — see README for dashboard setup
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
